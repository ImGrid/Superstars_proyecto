# App
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001
COOKIE_SECRET=change-me-min-16-chars

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=superstars_db

# JWT
JWT_SECRET=change-me-min-32-characters-for-security
