# App
NODE_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000
COOKIE_SECRET=change-me-min-16-chars

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=superstars_db

# JWT
JWT_SECRET=change-me-min-32-characters-for-security
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Password hashing
PASSWORD_PEPPER=change-me-min-32-characters-random-secret

# Session Limits
SESSION_ABSOLUTE_LIFETIME=30d
MAX_SESSIONS_PER_USER=5

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
